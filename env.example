# ============================================================
# HealthLink 統合環境変数サンプル
# このファイルをコピーして .env を作成してください
# cp .env.example .env
# ============================================================

# ---- アプリケーション ----
VITE_APP_NAME=HealthLink
NODE_ENV=development

# ---- バックエンド ----
PORT=8080
DATABASE_PATH=./backend/data/healthlink.db
CORS_ORIGIN=http://localhost:3000

# ---- JWT（必ず強力な文字列に変更してください） ----
JWT_ACCESS_SECRET=change_me_access_secret_min_32chars
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ---- セキュリティ ----
BCRYPT_ROUNDS=10

# ---- シードデータ（本番では必ず false） ----
LOAD_SEED_DATA=false

# ---- フロントエンド ----
VITE_API_URL=http://localhost:8080

# ---- ロールラベル（backend / frontend 共通） ----
# 病院（デフォルト）
VITE_LABEL_PATIENT=患者
VITE_LABEL_DOCTOR=医師
VITE_LABEL_NURSE=看護師

# 大学健康相談室の場合:
# VITE_LABEL_PATIENT=学生
# VITE_LABEL_DOCTOR=相談員
# VITE_LABEL_NURSE=保健相談員

# 企業健康管理室の場合:
# VITE_LABEL_PATIENT=社員
# VITE_LABEL_DOCTOR=産業医
# VITE_LABEL_NURSE=保健師

# ---- 研究利用ラベル ----
# 病院（デフォルト）
VITE_LABEL_RESEARCH=医療研究

# 大学の場合:
# VITE_LABEL_RESEARCH=学術研究

# 企業の場合:
# VITE_LABEL_RESEARCH=健康管理研究

# ---- タイムゾーン ----
TZ=Asia/Tokyo